{
  "name": "sobe/wp-theme",
  "type": "wordpress-theme",
  "license": "MIT",
  "description": "Sobe Agency WordPress theme boilerplate",
  "keywords": [
    "wordpress"
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "require": {
    "php": ">=8.4",
    "generoi/sage-woocommerce": "^1.1",
    "roots/acorn": "^6.0"
  },
  "require-dev": {
    "laravel/pint": "^1.20",
    "php-stubs/woocommerce-stubs": "^10.7",
    "phpstan/phpstan": "^2.1",
    "szepeviktor/phpstan-wordpress": "2.0.3"
  },
  "suggest": {
    "log1x/sage-directives": "A collection of useful Blade directives for WordPress and Sage (^1.0)."
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "post-autoload-dump": [
      "Roots\\Acorn\\ComposerScripts::postAutoloadDump"
    ],
    "analyse": "phpstan analyse --memory-limit=2G"
  }
}
