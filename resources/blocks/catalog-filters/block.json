{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sobe/catalog-filters",
  "version": "0.1.0",
  "title": "Catalog Filters",
  "icon": "filter",
  "category": "sobe-woocommerce",
  "description": "Single-instance product filter panel with a block-owned mobile drawer. Supported production placement is the Shop Sidebar widget area.",
  "example": {
    "attributes": {
      "showCategories": true,
      "showBrands": true,
      "showAttributes": true,
      "showPriceRange": true,
      "collapseByDefault": false
    }
  },
  "supports": {
    "html": false,
    "anchor": false,
    "className": false,
    "layout": false
  },
  "textdomain": "sobe",
  "attributes": {
    "brandsTaxonomy": {
      "type": "string",
      "default": "product_brand"
    },
    "showCategories": {
      "type": "boolean",
      "default": true
    },
    "showBrands": {
      "type": "boolean",
      "default": true
    },
    "showAttributes": {
      "type": "boolean",
      "default": true
    },
    "showPriceRange": {
      "type": "boolean",
      "default": true
    },
    "collapseByDefault": {
      "type": "boolean",
      "default": true
    }
  }
}
