{
  "name": "sobe",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "make:block": "node resources/scripts/make-block.js",
    "test": "jest --config jest.config.cjs",
    "check:patterns": "node resources/scripts/check-patterns.js",
    "check:upstream": "node resources/scripts/check-upstream.js",
    "translate": "npm run translate:pot && npm run translate:update",
    "translate:pot": "wp i18n make-pot . ./resources/lang/sobe.pot --include=\"theme.json,patterns,app,resources\"",
    "translate:update": "for file in ./resources/lang/*.po; do wp i18n update-po ./resources/lang/sobe.pot $file; done",
    "translate:compile": "npm run translate:mo && npm run translate:js",
    "translate:js": "wp i18n make-json ./resources/lang --pretty-print",
    "translate:mo": "wp i18n make-mo ./resources/lang ./resources/lang"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@roots/vite-plugin": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@wordpress/scripts": "^32.0.0",
    "babel-jest": "^29.0.0",
    "jest": "^29.0.0",
    "jest-environment-node": "^29.0.0",
    "laravel-vite-plugin": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.0"
  }
}
